<% checked = @profile.iso_languages.any? {|l| l == iso_languages } %>
<div class="col">
  <div class="form-check">
    <input class="form-check-input check_boxes optional"
           id="profile_iso_languages_<%= iso_languages %>"
           name="profile[iso_languages][]"
           value="<%= iso_languages %>"
           type="checkbox" <%="checked=true" if checked %> >
    <label class="form-check-label" for="profile_iso_languages_<%= iso_languages %>">
      <%= t("#{iso_languages}", scope: 'iso_639_1').capitalize %>
    </label>
  </div>
</div>
